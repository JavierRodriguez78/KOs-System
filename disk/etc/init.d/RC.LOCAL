# KOS init.d rc.local
# One command per line. Lines starting with # are comments.
# Each command executes /bin/<name>.elf with optional arguments.

clear

echo Booting KOS... welcome!

hello

# Targeted network exercise for E1000 validation in QEMU user-mode networking
ping -c 2 10.0.2.2

# Allocation-heavy runtime exercise
free
lshw
ifconfig
memtest
ss
